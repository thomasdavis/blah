{
  "name": "blah-mcp",
  "version": "1.11.0",
  "type": "module",
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('dist/index.js', '755')\"",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "inspector": "npx @modelcontextprotocol/inspector dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "bin": {
    "blah-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "agent",
    "host"
  ],
  "author": "Ajax",
  "license": "MIT",
  "description": "Barely Logical Agent Host",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.0",
    "commander": "^11.1.0",
    "dotenv": "^16.3.1",
    "node-fetch": "^3.3.2",
    "openai": "^4.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "shx": "^0.3.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
